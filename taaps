<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TAAPS 第二届理事会会员招募海报</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --tsinghua-purple: #660099;
            --premium-gold: #C5A059;
            --soft-white: #F9F9FB;
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f3f4f6;
        }
        .serif-title {
            font-family: 'Noto Serif SC', serif;
        }
        .gradient-bg {
            background: linear-gradient(135deg, var(--tsinghua-purple) 0%, #4a0070 100%);
        }
        .skyline-overlay {
            background-image: url('https://images.unsplash.com/photo-1525596662741-e94ff9f26de1?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center bottom;
            opacity: 0.15;
            mix-blend-mode: overlay;
        }
        .text-purple {
            color: var(--tsinghua-purple);
        }
        .bg-purple {
            background-color: var(--tsinghua-purple);
        }
        .card-shadow {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="p-4 md:p-8 flex justify-center">

    <div class="max-w-4xl w-full bg-white relative overflow-hidden card-shadow rounded-xl border border-gray-100">
        
        <header class="relative gradient-bg text-white p-10 md:p-16 text-center">
            <div class="absolute inset-0 skyline-overlay"></div>
            
            <div class="relative z-10">
                <div class="mb-8 flex justify-center">
                    <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center p-2">
                        <svg viewBox="0 0 100 100" class="w-12 h-12 text-purple-900 fill-current">
                            <path d="M50 5L10 25v50l40 20 40-20V25L50 5zm0 10.5l28 14v39.5L50 83.5 22 69V29.5l28-14z"/>
                            <path d="M50 35L35 45v10l15 10 15-10V45L50 35z"/>
                        </svg>
                    </div>
                </div>

                <h2 class="text-sm md:text-base tracking-widest opacity-90 mb-2 uppercase">
                    Tsinghua PBCSF Alumni Association Singapore (TAAPS)
                </h2>
                <h1 class="text-xl md:text-2xl font-light mb-6">
                    清华五道口金融EMBA新加坡校友会
                </h1>
                
                <div class="h-px w-24 bg-yellow-500 mx-auto mb-8"></div>
                
                <h3 class="serif-title text-4xl md:text-6xl mb-2 tracking-tight">
                    校友聚力 · 智启新程
                </h3>
                <p class="text-lg md:text-2xl font-light tracking-wide opacity-80 italic">
                    Empowering Alumni · Navigating the Future
                </p>

                <div class="mt-10 inline-block px-6 py-2 border border-yellow-500 rounded-full text-sm font-semibold tracking-widest text-yellow-500 uppercase">
                    2nd Term Council Recruitment (2026-2029)
                </div>
            </div>
        </header>

        <section class="p-8 md:p-12 bg-gray-50 border-b">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">President / 会长</p>
                    <h4 class="text-xl font-bold text-gray-800">Ng Yipin</h4>
                </div>
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">Executive President / 执行会长</p>
                    <h4 class="text-xl font-bold text-gray-800">Li Jun </h4>
                </div>
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">General Secretary / 秘书长</p>
                    <h4 class="text-xl font-bold text-gray-800">Cynthia Ding</h4>
                </div>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 border-b border-gray-100">
            
            <div class="p-8 md:p-12 border-r border-gray-100">
                <h5 class="serif-title text-2xl text-purple mb-8 flex items-center">
                    <span class="w-8 h-px bg-purple mr-3"></span>
                    会员专属权益 <span class="text-sm ml-2 font-sans font-normal text-gray-400">BENEFITS</span>
                </h5>
                
                <ul class="space-y-6">
                    <li class="flex items-start">
                        <div class="mt-1 mr-4 text-yellow-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <h6 class="font-bold text-gray-800">多元分会 (Sub-Clubs)</h6>
                            <p class="text-sm text-gray-500">高球、读书、品鉴、出海及传承分会等精彩活动</p>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <div class="mt-1 mr-4 text-yellow-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <h6 class="font-bold text-gray-800">品牌聚会 (Annual Events)</h6>
                            <p class="text-sm text-gray-500">中秋/春节全员团拜、年度招生聚会及跨校友会联谊</p>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <div class="mt-1 mr-4 text-yellow-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <h6 class="font-bold text-gray-800">优先入场 (Priority Access)</h6>
                            <p class="text-sm text-gray-500">享有官方活动优先参加资格及注册会员专属费用减免</p>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="p-8 md:p-12 bg-white">
                <h5 class="serif-title text-2xl text-purple mb-8 flex items-center">
                    <span class="w-8 h-px bg-purple mr-3"></span>
                    加入我们 <span class="text-sm ml-2 font-sans font-normal text-gray-400">JOIN US</span>
                </h5>

                <div class="space-y-6 mb-10">
                    <div class="bg-gray-50 p-4 rounded-lg">
                        <p class="text-xs text-gray-400 uppercase mb-1">Eligible Members / 招募对象</p>
                        <p class="text-sm text-gray-700 font-medium">金融EMBA、一带一路、GFD、CEO等项目的校友及在读学生</p>
                    </div>

                    <div class="bg-purple text-white p-6 rounded-lg text-center">
                        <p class="text-xs uppercase tracking-widest opacity-80 mb-1">Membership Fee / 会员费</p>
                        <h4 class="text-3xl font-bold">SGD 1,000</h4>
                        <p class="text-xs opacity-80">Per 3-Year Term / 本届三年期</p>
                    </div>
                </div>

                <div class="flex justify-between items-center px-4">
                    <div class="text-center">
                        <div class="w-8 h-8 rounded-full border-2 border-purple text-purple flex items-center justify-center font-bold text-xs mx-auto mb-2">1</div>
                        <p class="text-[10px] text-gray-500">提交申请</p>
                    </div>
                    <div class="flex-1 h-px bg-gray-200 mb-6"></div>
                    <div class="text-center">
                        <div class="w-8 h-8 rounded-full border-2 border-purple text-purple flex items-center justify-center font-bold text-xs mx-auto mb-2">2</div>
                        <p class="text-[10px] text-gray-500">资格审核</p>
                    </div>
                    <div class="flex-1 h-px bg-gray-200 mb-6"></div>
                    <div class="text-center">
                        <div class="w-8 h-8 rounded-full border-2 border-purple text-purple flex items-center justify-center font-bold text-xs mx-auto mb-2">3</div>
                        <p class="text-[10px] text-gray-500">缴费注册</p>
                    </div>
                </div>
            </div>
        </div>

        <section class="p-8 md:p-12 border-b border-gray-100 bg-white">
            <h5 class="serif-title text-2xl text-purple mb-8 flex items-center">
                <span class="w-8 h-px bg-purple mr-3"></span>
                往期精彩回顾 <span class="text-sm ml-2 font-sans font-normal text-gray-400">PAST HIGHLIGHTS</span>
            </h5>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="group cursor-pointer">
                    <div class="relative h-40 bg-gray-200 rounded-lg overflow-hidden mb-3 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1543968996-ee822b8176ba?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover transition-transform group-hover:scale-110 duration-500" alt="Festive Gathering">
                        <div class="absolute inset-0 bg-purple/10 group-hover:bg-transparent transition-all"></div>
                    </div>
                    <h6 class="font-bold text-gray-800 text-sm">节日团拜系列</h6>
                    <p class="text-xs text-gray-500 mt-1">春节与中秋全员聚会，每年一度，免费参加，共叙同窗情谊。</p>
                </div>
                <div class="group cursor-pointer">
                    <div class="relative h-40 bg-gray-200 rounded-lg overflow-hidden mb-3 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover transition-transform group-hover:scale-110 duration-500" alt="Admissions Gathering">
                        <div class="absolute inset-0 bg-purple/10 group-hover:bg-transparent transition-all"></div>
                    </div>
                    <h6 class="font-bold text-gray-800 text-sm">年度招生聚会</h6>
                    <p class="text-xs text-gray-500 mt-1">由清华五道口老师亲临主持，传递母校动态，助力新老校友交流。</p>
                </div>
                <div class="group cursor-pointer">
                    <div class="relative h-40 bg-gray-200 rounded-lg overflow-hidden mb-3 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover transition-transform group-hover:scale-110 duration-500" alt="Inter-Alumni Networking">
                        <div class="absolute inset-0 bg-purple/10 group-hover:bg-transparent transition-all"></div>
                    </div>
                    <h6 class="font-bold text-gray-800 text-sm">跨界联谊活动</h6>
                    <p class="text-xs text-gray-500 mt-1">联合兄弟校友会开展深度联谊，拓宽社交边界，促成合作良机。</p>
                </div>
            </div>
        </section>

        <section class="p-8 md:p-12 border-b border-gray-100 bg-gray-50/50">
            <h5 class="serif-title text-2xl text-purple mb-8 flex items-center">
                <span class="w-8 h-px bg-purple mr-3"></span>
                校友参访活动 <span class="text-sm ml-2 font-sans font-normal text-gray-400">2025-2026 ITINERARY</span>
            </h5>
            
            <div class="relative">
                <div class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-gray-200 z-0"></div>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">
                    <div class="flex flex-col items-center md:items-start">
                        <div class="w-10 h-10 rounded-full bg-purple text-white flex items-center justify-center font-bold mb-4 shadow-lg border-4 border-white">01</div>
                        <div class="text-center md:text-left">
                            <span class="text-xs font-bold text-purple uppercase tracking-wider">2025年8月</span>
                            <h6 class="text-lg font-bold text-gray-800 mt-1">印度尼西亚 · 巴厘岛</h6>
                            <p class="text-[11px] text-gray-500 mt-2">东南亚金融科技与数字化转型考察之旅。</p>
                        </div>
                    </div>
                    <div class="flex flex-col items-center md:items-start">
                        <div class="w-10 h-10 rounded-full bg-purple text-white flex items-center justify-center font-bold mb-4 shadow-lg border-4 border-white">02</div>
                        <div class="text-center md:text-left">
                            <span class="text-xs font-bold text-purple uppercase tracking-wider">2025年10月</span>
                            <h6 class="text-lg font-bold text-gray-800 mt-1 leading-tight">中亚：吉尔吉斯斯坦 & 哈萨克斯坦</h6>
                            <p class="text-[11px] text-gray-500 mt-2">探访比什凯克与阿拉木图，挖掘“一带一路”节点商机。</p>
                        </div>
                    </div>
                    <div class="flex flex-col items-center md:items-start">
                        <div class="w-10 h-10 rounded-full bg-purple text-white flex items-center justify-center font-bold mb-4 shadow-lg border-4 border-white">03</div>
                        <div class="text-center md:text-left">
                            <span class="text-xs font-bold text-purple uppercase tracking-wider">2026年1月</span>
                            <h6 class="text-lg font-bold text-gray-800 mt-1">马来西亚 · 吉隆坡&槟城</h6>
                            <p class="text-[11px] text-gray-500 mt-2">区域贸易中心及清真金融深度交流访谈。</p>
                        </div>
                    </div>
                    <div class="flex flex-col items-center md:items-start">
                        <div class="w-10 h-10 rounded-full bg-purple text-white flex items-center justify-center font-bold mb-4 shadow-lg border-4 border-white">04</div>
                        <div class="text-center md:text-left">
                            <span class="text-xs font-bold text-purple uppercase tracking-wider">2026年5月</span>
                            <h6 class="text-lg font-bold text-gray-800 mt-1">中国 · 深圳&香港</h6>
                            <p class="text-[11px] text-gray-500 mt-2">大湾区双城联动：资本市场与硬核科技互访。</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-12 bg-white/60 p-4 rounded-lg border border-purple/10 flex items-center justify-center text-center">
                <svg class="w-4 h-4 text-purple mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <p class="text-[11px] text-gray-500 font-medium">具体的考察主题及报名细则将于活动前2个月通过秘书处正式发布。</p>
            </div>
        </section>

        <section class="p-8 md:p-12 border-b border-gray-100 bg-white">
            <h5 class="serif-title text-2xl text-purple mb-8 flex items-center">
                <span class="w-8 h-px bg-purple mr-3"></span>
                各类分会活动 <span class="text-sm ml-2 font-sans font-normal text-gray-400">SUB-CLUB ACTIVITIES</span>
            </h5>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="bg-gray-50 p-5 rounded-xl border border-gray-100 flex items-center">
                    <div class="w-12 h-12 rounded-lg bg-purple/5 flex-shrink-0 flex items-center justify-center text-purple mr-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.407 2.67 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.407-2.67-1M12 16v1m4-12H8a2 2 0 00-2 2v14a2 2 0 002 2h8a2 2 0 002-2V6a2 2 0 00-2-2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div>
                        <h6 class="font-bold text-gray-800 text-sm">高球分会 (Golf Club)</h6>
                        <p class="text-xs text-gray-400">定期组织比赛与练习，切磋球技。</p>
                    </div>
                </div>
                
                <div class="bg-gray-50 p-5 rounded-xl border border-purple/20 flex items-start relative overflow-hidden group">
                    <div class="absolute top-0 right-0 bg-yellow-500 text-[9px] text-white px-2 py-0.5 font-bold tracking-tighter rounded-bl-lg">名家对话</div>
                    <div class="w-12 h-12 rounded-lg bg-purple/5 flex-shrink-0 flex items-center justify-center text-purple mr-4 mt-1">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.247 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div>
                        <h6 class="font-bold text-gray-800 text-sm">读书分会 (Book Club)</h6>
                        <p class="text-xs text-gray-400 mt-1">定期研讨佳作。曾邀<span class="text-purple font-semibold">马凯硕 (Kishore Mahbubani)</span>、<span class="text-purple font-semibold">曹慰德 (Federick Tsao)</span>等嘉宾深度分享。</p>
                    </div>
                </div>

                <div class="bg-gray-50 p-5 rounded-xl border border-gray-100 flex items-center">
                    <div class="w-12 h-12 rounded-lg bg-purple/5 flex-shrink-0 flex items-center justify-center text-purple mr-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div>
                        <h6 class="font-bold text-gray-800 text-sm">品鉴俱乐部 (Lifestyle)</h6>
                        <p class="text-xs text-gray-400">品鉴茶酒艺术，增进校友间情谊。</p>
                    </div>
                </div>
                <div class="bg-gray-50 p-5 rounded-xl border border-gray-100 flex items-center">
                    <div class="w-12 h-12 rounded-lg bg-purple/5 flex-shrink-0 flex items-center justify-center text-purple mr-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div>
                        <h6 class="font-bold text-gray-800 text-sm">出海传承 (Expansion)</h6>
                        <p class="text-xs text-gray-400">关注海外发展，支持业务与传承。</p>
                    </div>
                </div>
            </div>
            <p class="mt-6 text-[10px] text-gray-400 italic text-center">* 各分会活动费用由参与者共担，不从校友会会费中支出。</p>
        </section>

        <footer class="bg-gray-900 text-white p-10 md:p-12">
            <div class="flex flex-col md:flex-row items-center justify-between gap-10">
                <div class="text-center md:text-left">
                    <h5 class="text-yellow-500 font-bold text-lg mb-2">第二届换届大会暨成立仪式</h5>
                    <p class="text-sm text-gray-400 mb-1">Tentative Date: August 2026</p>
                    <p class="text-sm text-gray-400">暂定日期：2026年8月 (与年度招生同步)</p>
                </div>

                <div class="flex flex-col items-center">
                    <div class="w-32 h-32 bg-white p-2 rounded-lg mb-3">
                        <div class="w-full h-full bg-gray-100 flex items-center justify-center border-2 border-dashed border-gray-300">
                            <span class="text-[10px] text-gray-400 text-center font-bold">SCAN TO<br>APPLY</span>
                        </div>
                    </div>
                    <p class="text-[10px] tracking-widest text-gray-500 uppercase">立即扫码申请加入</p>
                </div>
            </div>
            
            <div class="mt-10 pt-8 border-t border-gray-800 text-center text-xs text-gray-500">
                <p>© 2026 Tsinghua PBCSF Alumni Association Singapore. All Rights Reserved.</p>
            </div>
        </footer>
    </div>

</body>
</html>
